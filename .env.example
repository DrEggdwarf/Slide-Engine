# Le SEUL secret : mot de passe de la régie (déverrouille le pilotage + le QR).
# En local il est facultatif (défaut "demo", et localhost est admin automatiquement).
# En prod, définis-le impérativement.
PRESENTER_PASSWORD=change-moi

# Optionnel : fournir le SHA-256 du mot de passe au lieu du clair.
#   echo -n "monmotdepasse" | sha256sum
# PRESENTER_PASSWORD_SHA256=

# Port du serveur de prod (server/index.js).
PORT=3000
